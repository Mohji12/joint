# Backend API base URL (no trailing slash). Used by src/lib/api.ts (getBaseUrl).
# Deployed API:
VITE_API_URL=https://back.jointlly.in
# Local FastAPI during development:
# VITE_API_URL=http://127.0.0.1:8001

# Backend SMTP / email configuration (mirrors jointlly_backend/.env.example)
# These are here for convenience when running everything from the project root.
SMTP_HOST=smtp.zeptomail.in
SMTP_PORT=587
SMTP_USERNAME=emailapikey
SMTP_PASSWORD=your-zeptomail-smtp-password
SMTP_FROM_EMAIL=no-reply@jointlly.com

# Frontend base URL used in email links from backend
FRONTEND_BASE_URL=https://jointlly.com
