# Database - AWS RDS MySQL
# Format: mysql+aiomysql://user:password@host:port/database
# Note: Special characters in password should be URL-encoded (# = %23)
DATABASE_URL=mysql+aiomysql://user:password@host:3306/jointly

# JWT Authentication
JWT_SECRET_KEY=dummy-jwt-secret-key-for-development-min-32-chars-long
JWT_ALGORITHM=HS256
# Access token lifetime is fixed at 480 minutes (8 hours) in app/config.py; this line is ignored.
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# SMTP / Email (ZeptoMail)
# NOTE: Do NOT commit real production secrets. These are examples only.
SMTP_HOST=smtp.zeptomail.in
SMTP_PORT=587
SMTP_USERNAME=emailapikey
SMTP_PASSWORD=your-zeptomail-smtp-password
SMTP_FROM_EMAIL=no-reply@jointlly.com
# Optional: reachable support inbox (sets Reply-To; helps inbox placement vs bare no-reply)
# SMTP_REPLY_TO=support@jointlly.com

# Frontend base URL used in email links and default email logo path
FRONTEND_BASE_URL=https://jointlly.com
# Optional: full public HTTPS URL for logo in HTML emails (defaults to FRONTEND_BASE_URL/logo-navbar-dark.svg)
# EMAIL_LOGO_URL=https://jointlly.com/logo-navbar-dark.svg

# Razorpay
RAZORPAY_KEY_ID=rzp_test_dummy1234567890
RAZORPAY_KEY_SECRET=dummy_secret_key_abcdefghijklmnopqrstuvwxyz1234567890

# Application
APP_NAME=Jointly Real Estate Platform
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# AWS S3 (optional – only if not using Cloudinary for uploads)
# AWS_S3_BUCKET=cedat1
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Cloudinary (for image/file uploads – set these to enable uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# OpenAI (for 2D plan preview – set to enable "Generate plan preview")
OPENAI_API_KEY=your-openai-api-key
